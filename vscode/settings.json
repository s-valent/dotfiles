{
    // "editor.fontFamily": "Menlo",
    // "editor.fontSize": 12.6,
    // "terminal.integrated.fontSize": 13,
    // "terminal.integrated.cursorWidth": 2,
    // "terminal.integrated.lineHeight": 1.2,
    // "window.zoomLevel": -0.2,

    // "editor.fontFamily": "Monego",
    // "editor.fontSize": 12.6,
    // "terminal.integrated.fontSize": 13,
    // "terminal.integrated.lineHeight": 1.1,
    // "window.zoomLevel": -0.15,

    "editor.fontFamily": "Ubuntu Mono",
    "editor.fontSize": 12.9,
    "terminal.integrated.fontSize": 13,
    "terminal.integrated.lineHeight": 1.35,
    "terminal.integrated.letterSpacing": 1,
    "editor.cursorWidth": 3,
    "terminal.integrated.cursorWidth": 3,
    "editor.lineHeight": 1.35,
    "editor.letterSpacing": 0.1,
    "window.zoomLevel": -0.1,

    // "editor.fontFamily": "Fira Code",
    // "editor.fontSize": 13,
    // "terminal.integrated.fontSize": 13,
    // "editor.letterSpacing": -0.2,
    // "editor.lineHeight": 1.4,
    // "terminal.integrated.lineHeight": 1.2,
    // "window.zoomLevel": -0.2,

    // "editor.fontFamily": "SF Mono",
    // "editor.fontSize": 12.5,
    // "editor.fontWeight": "500",
    // "errorLens.fontWeight": "500",
    // "editor.letterSpacing": -0.05,
    // "editor.lineHeight": 1.4,
    // "terminal.integrated.fontSize": 13,
    // "terminal.integrated.fontWeight": "500",
    // "terminal.integrated.lineHeight": 1.2,
    // "window.zoomLevel": -0.2,

    // "editor.fontFamily": "JB Nerd",
    // "editor.fontSize": 11.7,
    // "terminal.integrated.fontSize": 12,
    // "editor.lineHeight": 1.35,

    "workbench.colorTheme": "Tomorrow Gray",
    "editor.wordWrap": "on",
    "diffEditor.ignoreTrimWhitespace":false,
    "errorLens.scrollbarHackEnabled": true,
    "errorLens.enableOnDiffView": true,
    "errorLens.enabledInMergeConflict": false,
    "editor.multiCursorModifier": "ctrlCmd",
    "editor.minimap.enabled": false,
    "telemetry.telemetryLevel": "off",
    "update.mode": "manual",
    "editor.scrollbar.horizontal": "hidden",
    "editor.scrollBeyondLastColumn": 0,
    "workbench.startupEditor": "none",
    "editor.padding.top": 15,
    "editor.padding.bottom": 205,
    "editor.scrollBeyondLastLine": false,
    "editor.scrollbar.verticalScrollbarSize": 10,
    "window.newWindowDimensions": "inherit",
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    "editor.smoothScrolling": true,
    "editor.semanticHighlighting.enabled": false,
    "editor.guides.highlightActiveIndentation": false,
    "editor.guides.indentation": false,
    "security.workspace.trust.banner": "never",
    "security.workspace.trust.enabled": false,
    "workbench.panel.defaultLocation": "bottom",
    "workbench.iconTheme": "material-icon-theme",
    "material-icon-theme.folders.theme": "classic",
    "material-icon-theme.opacity": 0.7,
    "python.autoComplete.extraPaths": [
        ".",
        ".."
    ],
    "python.analysis.extraPaths": [
        ".",
        ".."
    ],
    "editor.showFoldingControls": "never",
    "editor.unicodeHighlight.includeStrings": false,
    "window.restoreWindows": "none",
    "editor.bracketPairColorization.enabled": false,
    "files.exclude": {
        "**/__pycache__": true,
        "**/.idea": true,
        "**/.ipynb_checkpoints": true
    },
    "terminal.integrated.scrollback": 1000000,
    "terminal.integrated.shellIntegration.decorationsEnabled": "never",
    "explorer.confirmDelete": false,
    "editor.dragAndDrop": false,
    "editor.emptySelectionClipboard": false,
    "editor.renderLineHighlight": "all",
    "window.title": "${activeEditorMedium}",
    "breadcrumbs.enabled": false,
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "python.analysis.autoSearchPaths": false,
    "workbench.localHistory.enabled": false,
    // "python.defaultInterpreterPath": "/usr/local/bin/python",
    "python.analysis.typeCheckingMode": "off",
    "git.openRepositoryInParentFolders": "never",
    "files.associations": {
        "*.jinja2": "jinja-py"
    },
    "editor.largeFileOptimizations": false,
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter"
    },
    "editor.inlayHints.enabled": "off",
    "explorer.autoRevealExclude": {
        "**/venv": true,
        "**/.venv": true
    },
    "editor.hideCursorInOverviewRuler": true,
    "terminal.integrated.macOptionIsMeta": true,
    "workbench.layoutControl.enabled": false,
    "workbench.editor.empty.hint": "hidden",
    "workbench.activityBar.location": "top",
    "explorer.confirmDragAndDrop": false,
    "workbench.panel.opensMaximized": "preserve",
    "python.terminal.activateEnvironment": false,
    "git.ignoreLegacyWarning": true,
    "editor.inlineSuggest.suppressSuggestions": true,
    "extensions.ignoreRecommendations": true,
    "references.preferredLocation": "view",
    "editor.selectionHighlight": false,
    "workbench.settings.editor": "json",
    "ruff.fixAll": false,
    "ruff.organizeImports": false,
    "terminal.integrated.shellIntegration.enabled": false,
    "window.customTitleBarVisibility": "windowed",
    "editor.stickyScroll.enabled": false,
    "yaml.schemas": {
        "https://json.schemastore.org/any.json": ["*.tests.yml", "*.tests.yaml", "*.test.yml", "*.test.yaml"]
    },
    "remote.autoForwardPorts": false,
    "vim.vimrc.path": "~/.vim/vimrc",
    "vim.vimrc.enable": true,
    "vim.useSystemClipboard": true,
    "editor.lineNumbers": "relative",
    "editor.cursorBlinking": "solid",
    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": ["g", "r"],
            // "commands": ["editor.action.showReferences"],
            "commands": ["references-view.findReferences"],
            "silent": true
        }
    ],
    "extensions.experimental.affinity": {
        "asvetliakov.vscode-neovim": 1
    }
}
